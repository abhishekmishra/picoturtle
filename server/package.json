{
  "name": "picoturtle-server",
  "version": "0.0.0",
  "private": true,
  "bin": "./bin/www",
  "scripts": {
    "start": "node ./bin/www",
    "start-dev": "nodemon ./bin/www",
    "pkg": "pkg . -t node10-linux-x64,node10-win-x64,node10-macos-x64 --out-path ./dist",
    "pkg-local": "pkg . -t node10 --out-path ./dist"
  },
  "dependencies": {
    "cookie-parser": "~1.4.3",
    "debug": "~2.6.9",
    "express": "~4.16.0",
    "lock": "^1.1.0",
    "morgan": "~1.9.0",
    "picoturtle-client-js": "file:../client/picoturtle-client-js",
    "project-name-generator": "^2.1.6",
    "uuid": "^3.3.2"
  },
  "devDependencies": {
    "nodemon": "^1.18.10",
    "pkg": "^4.3.7"
  },
  "pkg": {
    "assets": "node_modules/picoturtle-client-js/**/*"
  }
}
